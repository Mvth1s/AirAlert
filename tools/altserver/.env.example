# Identifiant UDID de l'iPhone (obtenu avec : idevice_id -l)
DEVICE_UDID=

# Apple ID (email)
APPLE_ID=

# Mot de passe spécifique à l'app (pas ton mot de passe principal)
# Générer sur : https://appleid.apple.com → Sécurité → Mots de passe spécifiques
APPLE_PASSWORD=

# Chemin vers le dossier contenant AirAlert.ipa
# Laisser vide pour utiliser /tmp (télécharger l'IPA là)
IPA_PATH=
